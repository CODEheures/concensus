---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ReadingMode from '../../components/ReadingMode.astro';
import PolisEmbed from '../../components/PolisEmbed.astro';
import { statutInfo } from '../../lib/statut';

export async function getStaticPaths() {
  const fiches = await getCollection('fiches');
  return fiches.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const f = entry.data;
const st = statutInfo(f.statut);
---

<Base title={`${f.titre} — Consensus`} description={f.chapo}>
  <div class="layout">
    <div class="main">
      {
        st.banner && (
          <div class={`statut-banner ${st.ton}`}>
            <strong>{st.label}.</strong>
            <span>{st.banner}</span>
          </div>
        )
      }
      <nav class="breadcrumb">
        <span>{f.fil.ministere}</span><span class="sep">›</span>
        <span>{f.fil.theme}</span><span class="sep">›</span><span>{f.fil.sousTheme}</span>
      </nav>

      <div class="tags">
        {f.tags.map((t) => <span class="tag">{t}</span>)}
      </div>

      <h1>{f.titre}</h1>
      <p class="chapo">{f.chapo}</p>

      <ReadingMode />

      <Content />

      <div class="charte">
        <strong>Notre principe.</strong> Cette fiche n'a pas de couleur politique. Elle
        expose ce que les données établissent, ce qu'elles ne tranchent pas, distingue ce
        qui est <span class="badge eprouve">ÉPROUVÉ</span> de ce qui est
        <span class="badge emergent">ÉMERGENT</span>, et laisse le débat au vote. Une bonne
        idée n'a ni gauche ni droite.
        {
          f.origine.elaboreeAvec && (
            <>
              {' '}<em>Fiche élaborée avec {f.origine.elaboreeAvec}, revue selon la charte.</em>
            </>
          )
        }
      </div>
    </div>

    <aside class="aside" id="voteAside">
      <a class="vote-back" id="voteBack" href="#">← Retour à la fiche</a>
      <PolisEmbed conversationId={f.polis.conversationId} />
    </aside>
  </div>

  <script is:inline>
    (function () {
      var open = document.getElementById('voteOpen');
      var back = document.getElementById('voteBack');
      if (open)
        open.addEventListener('click', function () {
          document.body.classList.add('vote-open');
        });
      if (back)
        back.addEventListener('click', function (e) {
          e.preventDefault();
          document.body.classList.remove('vote-open');
        });

      // Cale le bouton « Voter » juste sous le titre collant : on expose la
      // hauteur réelle du <h1> (qui peut passer sur 2 lignes) en variable CSS.
      function syncTitleHeight() {
        var h1 = document.querySelector('.main h1');
        if (h1)
          document.documentElement.style.setProperty(
            '--title-sticky-h',
            h1.offsetHeight + 'px',
          );
      }
      syncTitleHeight();
      window.addEventListener('resize', syncTitleHeight);
      window.addEventListener('load', syncTitleHeight);
    })();
  </script>
</Base>
