---
import { getCollection } from 'astro:content';

const fiches = await getCollection('fiches');
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Consensus</title>
  </head>
  <body>
    <h1>Consensus</h1>
    <p>POC — fiches benchmark soumises à la délibération citoyenne.</p>
    <ul>
      {
        fiches.map((fiche) => (
          <li>
            <a href={`/fiches/${fiche.id}/`}>{fiche.data.titre}</a>
          </li>
        ))
      }
    </ul>
  </body>
</html>
