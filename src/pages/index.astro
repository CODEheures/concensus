---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { statutInfo } from '../lib/statut';

const fiches = await getCollection('fiches');
---

<Base title="Consensus">
  <main class="home">
    <h1>Consensus</h1>
    <p class="chapo">
      POC — fiches benchmark soumises à la délibération citoyenne.
    </p>
    <ul class="fiche-list">
      {
        fiches.map((fiche) => {
          const st = statutInfo(fiche.data.statut);
          return (
            <li>
              <a href={`/fiches/${fiche.id}/`}>{fiche.data.titre}</a>
              {st.ton !== 'neutre' && (
                <span class={`fiche-chip ${st.ton}`}>{st.label}</span>
              )}
            </li>
          );
        })
      }
    </ul>
  </main>
</Base>

<style>
  .home {
    max-width: 760px;
    margin: 0 auto;
    padding: 28px 20px 80px;
  }
  .fiche-list {
    list-style: none;
    padding: 0;
    margin: 22px 0 0;
  }
  .fiche-list li {
    padding: 12px 0;
    border-bottom: 1px solid var(--trait);
  }
  .fiche-list a {
    font-family: var(--serif);
    font-size: 18px;
  }
</style>
